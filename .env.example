# Copy to .env and fill in. Never commit .env.

# LLM inference
ANTHROPIC_API_KEY=

# path to your profile.md (gitignored)
CANDIDATE_PROFILE=profile.md

# company research (optional)
GOOGLE_API_KEY=

# pipeline working directory
JOBS_DIR=./data

# browser automation
SKYVERN_API_KEY=

SKYVERN_BASE_URL=

TELEGRAM_CHAT_ID=

# notification sink
TELEGRAM_TOKEN=

# comma-separated long-running scripts to supervise (relative to JOBS_DIR)
WATCHED_PROCESSES=

# comma-separated daily run times for the scheduler
RUN_TIMES=07:00,12:00,17:00
